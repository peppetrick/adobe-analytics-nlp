# ============================================
# .env.example - Environment Configuration
# ============================================

# Adobe OAuth Configuration
ADOBE_CLIENT_ID=your_client_id_here
ADOBE_CLIENT_SECRET=your_client_secret_here
ADOBE_REDIRECT_URI=https://localhost:8011/api/auth/callback
ADOBE_SCOPES=openid,AdobeID,read_organizations,additional_info.projectedProductContext,additional_info.job_function

# Adobe Analytics
ADOBE_COMPANY_ID=your_company_id
DEFAULT_RSID=your_report_suite_id

# Claude API (for NLP)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama (alternative to Claude)
USE_LOCAL_MODEL=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Server Configuration
PORT=8011
NODE_ENV=development

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false

# Session Configuration
SESSION_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_MIN_32_CHARS
SESSION_NAME=adobe_analytics_sid
SESSION_MAX_AGE=86400000

# Security
CSRF_ENABLED=true
SECURE_COOKIES=true
CORS_ORIGIN=https://localhost:8011
